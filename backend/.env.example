PORT=5000
NODE_ENV=development

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/fintrack-ai

# JWT Secrets (Generate secure random hashes in production)
ACCESS_TOKEN_SECRET=replace_with_a_long_random_hash_key_12345
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_SECRET=replace_with_another_long_random_hash_key_67890
REFRESH_TOKEN_EXPIRE=7d

# Cloudinary Config (Required for receipt/avatar image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini AI Config (Required for receipt scanning)
GEMINI_API_KEY=your_gemini_api_key
